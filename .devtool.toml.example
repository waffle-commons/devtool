[ollama]
endpoint = "http://localhost:11434"
model = "gemma4:latest"
embedding_model = "qwen3-embedding:latest"
show_thoughts = true
request_timeout = 600
num_ctx = 16384

[models]
default   = "gemma4:latest"
coding    = "qwen3-coder:latest"
fast      = "qwen3:0.6b"
review    = "gemma4:31b"
embedding = "qwen3-embedding:latest"
